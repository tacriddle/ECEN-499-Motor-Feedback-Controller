/* USER CODE BEGIN 4 */
void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim) {
    if (htim->Instance == TIM3) {
        uint32_t current_dma_index = SLOTS_ON_DISK - __HAL_DMA_GET_COUNTER(&hdma_tim2_ch1);

        if (current_dma_index != last_dma_index) {
            uint32_t newest_val = capture_buffer[(current_dma_index == 0) ? (SLOTS_ON_DISK - 1) : (current_dma_index - 1)];
            // LOOK BACK WINDOW: Find the index 6 pulses ago
            int oldest_idx = (int)current_dma_index - WINDOW;
            if (oldest_idx < 0) oldest_idx += SLOTS_ON_DISK;
            uint32_t oldest_val = capture_buffer[oldest_idx];

            uint32_t total_time;
            if (newest_val > oldest_val) total_time = newest_val - oldest_val;
            else total_time = (0xFFFFFFFF - oldest_val) + newest_val;

            if (total_time > 0) {
                // STEP 1: Raw Math + Calibration
                float rpm_raw = (conversion_constant / (float)total_time) * calibration_factor;

                // STEP 2: Median Filter (reject outliers)
                median_buffer[median_idx] = rpm_raw;
                median_idx = (median_idx + 1) % 3;

                float rpm_filtered = get_median_of_3(median_buffer[0],
                                                     median_buffer[1],
                                                     median_buffer[2]);

                // STEP 3: Alpha Filter (Smoothing)
                current_rpm = (rpm_filtered * alpha) + (current_rpm * (1.0f - alpha));
            }

            last_dma_index = current_dma_index;
            last_tick = HAL_GetTick();
        } else {
            if (HAL_GetTick() - last_tick > (uint32_t)timeout_ms) {
                current_rpm = 0;
                // Clear median buffer when stopped to prevent old data from lingering
                median_buffer[0] = median_buffer[1] = median_buffer[2] = 0;
            }
        }
    }
}
/* USER CODE END 4 */

