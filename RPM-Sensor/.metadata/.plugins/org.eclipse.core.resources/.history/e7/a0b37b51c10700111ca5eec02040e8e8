void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim) {
    if (htim->Instance == TIM3) {
        // 1. Check where the DMA is currently writing in the buffer
        // __HAL_DMA_GET_COUNTER returns how many items are REMAINING
        uint32_t current_dma_index = SLOTS_ON_DISK - __HAL_DMA_GET_COUNTER(&hdma_tim2_ch1);

        // 2. See if the index has changed (meaning new pulses occurred)
        if (current_dma_index != last_dma_index) {

            // Calculate time difference between the newest and oldest pulses in the buffer
            // To keep it simple, we'll use the "Full Rotation" delta
            uint32_t total_time = capture_buffer[SLOTS_ON_DISK - 1] - capture_buffer[0];

            if (total_time > 0) {
                float rpm_raw = 60000000.0f / (float)total_time;

                // Exponential Moving Average (EMA) to smooth out vibration
                current_rpm = (rpm_raw * alpha) + (current_rpm * (1.0f - alpha));
            }

            last_dma_index = current_dma_index;
            last_tick = HAL_GetTick(); // Reset timeout
        } else {
            // No movement? Check for stall
            if (HAL_GetTick() - last_tick > timeout_ms) {
                current_rpm = 0;
            }
        }

        // 3. THIS IS WHERE YOU WILL ADD MOTOR CONTROL MATH
        // e.g., if (current_rpm < target) { Increase PWM }
    }
}
