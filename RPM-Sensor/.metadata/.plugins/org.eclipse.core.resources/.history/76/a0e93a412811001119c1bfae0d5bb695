/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_DMA_Init();
  MX_USART2_UART_Init();
  MX_TIM2_Init();
  /* USER CODE BEGIN 2 */

  DWT_Init();

//  HAL_TIM_Base_Start_IT(&htim3);

  // This tells the DMA: "Every time TIM2 captures a value, put it in capture_buffer."
  HAL_TIM_IC_Start_DMA(&htim2, TIM_CHANNEL_1, capture_buffer, DMA_BUF_SIZE);

  // MANUALLY enable the interrupt for EVERY capture event
//  __HAL_TIM_ENABLE_IT(&htim2, TIM_IT_CC1);

  uint8_t print = 1;
  uint8_t last_button = 1;
  HAL_GPIO_WritePin(LD2_GPIO_Port, LD2_Pin, GPIO_PIN_SET);

  printf("----------------------------------------------------------------------\r\n");
  printf("----------------------------------------------------------------------\r\n");
  printf("----------------------------------------------------------------------\r\n");

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
//	  /* Check for Half-Transfer Flag on Stream 5 */
//	  if (__HAL_DMA_GET_FLAG(&hdma_tim2_ch1, __HAL_DMA_GET_HT_FLAG_INDEX(&hdma_tim2_ch1)))
//	  {
//		  // Clear flag immediately
//		  __HAL_DMA_CLEAR_FLAG(&hdma_tim2_ch1, __HAL_DMA_GET_HT_FLAG_INDEX(&hdma_tim2_ch1));
//
//		  uint32_t start = capture_buffer[0];
//		  uint32_t end = capture_buffer[11];
//		  period_ticks = (end >= start) ? (end - start) : (0xFFFFFFFF - start + end);
//		  new_rpm_data = 1;
//	  }
//
//	  /* Check for Transfer-Complete Flag on Stream 5 */
//	  if (__HAL_DMA_GET_FLAG(&hdma_tim2_ch1, __HAL_DMA_GET_TC_FLAG_INDEX(&hdma_tim2_ch1)))
//	  {
//		  // Clear flag immediately
//		  __HAL_DMA_CLEAR_FLAG(&hdma_tim2_ch1, __HAL_DMA_GET_TC_FLAG_INDEX(&hdma_tim2_ch1));
//
//		  uint32_t start = capture_buffer[12];
//		  uint32_t end = capture_buffer[23];
//		  period_ticks = (end >= start) ? (end - start) : (0xFFFFFFFF - start + end);
//		  new_rpm_data = 1;
//	  }

	  // Process new RPM measurement
	  if (new_rpm_data) {
		  start = DWT->CYCCNT;

		  new_rpm_data = 0;

		  // Convert to RPM
		  float rpm_raw = conversion_and_calibration / (float)period_ticks;

		  // Median filter (reject outliers/spikes)
		  median_buffer[median_idx] = rpm_raw;
		  median_idx++;
		  if (median_idx >= 3) median_idx = 0;

		  float rpm_filtered = get_median_of_3(median_buffer[0], median_buffer[1], median_buffer[2]);

		  // Alpha filter (smooth)
		  current_rpm = (alpha * rpm_filtered) + ((1.0f - alpha) * current_rpm);

		  // Update timeout timestamp
		  last_tick = HAL_GetTick();

//		  end = DWT->CYCCNT;
//		  duration = end - start; // Total clock cycles spent
//		  printf("%lu\r\n", duration);
		  acc_main_logic += (DWT->CYCCNT - start);
	  }




	  // --- The Auditor: Calculate results every 1 second ---
	      if (HAL_GetTick() - last_report_tick >= 1000) {
	          // Calculate percentages (Assuming 180MHz)
	          load_half_pct = (acc_isr_half * 100) / 180000000;
	          load_full_pct = (acc_isr_full * 100) / 180000000;
	          load_main_pct = (acc_main_logic * 100) / 180000000;

	          printf("--- CPU LOAD REPORT ---\r\n");
	          printf("RPM ISR:   %.4f%%\r\n", load_half_pct);
	          printf("Motor ISR: %.4f%%\r\n", load_full_pct);
	          printf("Main Math: %.4f%%\r\n", load_main_pct);
	          printf("Total:     %.4f%%\r\n\n", load_half_pct + load_full_pct + load_main_pct);

	          // Reset all accumulators
	          acc_isr_half = 0;
	          acc_isr_full = 0;
	          acc_main_logic = 0;
	          last_report_tick = HAL_GetTick();
	      }







	  // timeout logic to detect when RPM = 0
	  if (HAL_GetTick() - last_tick > (uint32_t)timeout_ms) {
		  current_rpm = 0;
		  median_buffer[0] = median_buffer[1] = median_buffer[2] = 0;
	  }






	  // start and stop printing to serial on button1 press
	  uint8_t current_button = HAL_GPIO_ReadPin(B1_GPIO_Port, B1_Pin);
	  if (last_button == GPIO_PIN_SET && current_button == GPIO_PIN_RESET)
	  {
	      print = !print;
	      HAL_GPIO_TogglePin(LD2_GPIO_Port, LD2_Pin);
	  }
	  last_button = current_button;

	  // Print RPM to Serial every 100ms
	  if (print && (HAL_GetTick() - last_print > 100))
	  {
		  printf("%.0f\r\n", current_rpm);
		  last_print = HAL_GetTick();
	  }
  }
  /* USER CODE END 3 */
}

