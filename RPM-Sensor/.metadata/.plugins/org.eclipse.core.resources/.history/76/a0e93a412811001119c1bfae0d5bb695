/////////////////////////////// CPU cylce tracking
void DWT_Init(void) {
    // 1. Enable the trace peripheral (required for DWT)
    CoreDebug->DEMCR |= CoreDebug_DEMCR_TRCENA_Msk;

    // 3. Reset the cycle counter
    DWT->CYCCNT = 0;

    // 4. Start the cycle counter
    DWT->CTRL |= DWT_CTRL_CYCCNTENA_Msk;
}
uint32_t start, end, duration;
volatile uint32_t acc_isr_half = 0;    // RPM Sensor Interrupt
volatile uint32_t acc_isr_full = 0;  // Motor PWM/Control Interrupt
uint32_t acc_main_logic = 0;          // Your if(new_rpm_data) block
float load_half_pct = 0;
float load_full_pct = 0;
float load_main_pct = 0;
float last_report_tick = 0;

