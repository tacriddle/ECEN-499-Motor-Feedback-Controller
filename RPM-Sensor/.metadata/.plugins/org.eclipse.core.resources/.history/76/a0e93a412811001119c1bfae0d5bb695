uint8_t CALC_WINDOW_MAX_IDX = CALC_WINDOW_SIZE - 1;
uint8_t DMA_BUF_MAX_IDX = DMA_BUF_SIZE - 1;

// used to convert microsecond timing measurements to minutes and calibrate to match actual RPM
// Conversion: us between pulses → RPM
//   60,000,000 us/min ÷ (SLOTS_ON_DISK pulses/rev) × CALC_WINDOW pulses
// Calibration: multiply by CAL_FACTOR to correct measurement error
float conversion_and_calibration = (60000000.0f * CALC_WINDOW_SIZE * CAL_FACTOR) / SLOTS_ON_DISK;

uint32_t IC_Val1 = 0;
uint32_t IC_Val2 = 0;
uint32_t Difference = 0;
uint8_t Is_First_Captured = 0;  // 0 = waiting for first edge, 1 = waiting for second

uint32_t last_pulse_timestamp = 0;

float current_rpm = 0;

volatile uint32_t period_ticks = 0;
volatile uint8_t new_rpm_data = 0;

float median_buffer[3] = {0, 0, 0}; // median rpm sensor filtering to reject outliers
uint8_t median_idx = 0;

float alpha = 0.3f; 				// used for rolling avergae for rpm (30% weight to new data, 70% to history)
//float calibration_factor = 0.966f;  // used for rpm calculation, measurement is linearly off from actual


uint32_t last_tick = 0;         // For timeout logic
float timeout_ms = 60000.0f / (MINIMUM_RPM * SLOTS_ON_DISK);

static uint32_t last_print = 0;
char uart_buf[50];

