0800113c <LCD_Init>:
void LCD_Data(uint8_t data) {
    lcd_write4(data & 0xF0, 1);         // Upper nibble (RS=1)
    lcd_write4((data << 4) & 0xF0, 1);  // Lower nibble (RS=1)
}

