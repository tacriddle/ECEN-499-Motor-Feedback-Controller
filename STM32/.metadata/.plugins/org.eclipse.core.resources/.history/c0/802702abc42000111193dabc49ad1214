#include "telemetry.h"
#include "rpm_sensor.h"
#include "motor_control.h"
#include <stdio.h>
#include <string.h>
#include <stdlib.h>

extern UART_HandleTypeDef huart1;
extern UART_HandleTypeDef huart2;

char esp32_tx_buffer[10]; 			// buffer for rpm string to be sent to ESP32
uint32_t last_ESP32_transmit = 0;	// used to transmit to ESP32 after every 100ms

char esp32_rx_buffer[10];   // To hold the incoming string (e.g., "3000\n") from ESP32
uint8_t esp32_rx_index = 0; // Current position in buffer
uint8_t esp32_rx_char;      // Temp storage for 1 byte

// for receiving over USB
char rx_buffer[10];
uint8_t rx_index = 0;
uint8_t rx_data;

void Telemetry_Init(void) {
    char greeting[] = "Motor Controller Ready\r\nType duty (0-100) and press Enter\r\n>> ";
    HAL_UART_Transmit(&huart2, (uint8_t*)greeting, strlen(greeting), 100);
    HAL_UART_Receive_IT(&huart2, &rx_data, 1);
    HAL_UART_Receive_IT(&huart1, &esp32_rx_char, 1);
}

void Telemetry_Transmit_ESP32(void) {
    if (HAL_GetTick() - last_ESP32_transmit >= 100) {
        if (huart1.gState == HAL_UART_STATE_READY) {
            int len = sprintf(esp32_tx_buffer, "%d,%d\n", (int)current_rpm, (int)current_pwm);
            HAL_UART_Transmit_DMA(&huart1, (uint8_t*)esp32_tx_buffer, len);
            last_ESP32_transmit = HAL_GetTick();
        }
    }
}

void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart) {
	// recieved byte from ESP32
    if (huart->Instance == USART1) {
        if (esp32_rx_char == '\n' || esp32_rx_char == '\r') {
            if (esp32_rx_index > 0) {
                esp32_rx_buffer[esp32_rx_index] = '\0';
                target_rpm = atoi(esp32_rx_buffer);
                printf("TARGET RPM: %d\r\n", target_rpm);
                esp32_rx_index = 0;
            }
        }
        else if (esp32_rx_index < sizeof(esp32_rx_buffer) - 1) {
            if (esp32_rx_char >= '0' && esp32_rx_char <= '9') {
                esp32_rx_buffer[esp32_rx_index++] = esp32_rx_char;
            }
        }
        HAL_UART_Receive_IT(&huart1, &esp32_rx_char, 1);
    }

    // received input over USB
    if (huart->Instance == USART2) {
        if (rx_data == '\r' || rx_data == '\n') {
            rx_buffer[rx_index] = '\0';
            float new_duty = atof(rx_buffer);
            extern TIM_HandleTypeDef htim1;
            void Set_Motor_Duty(TIM_HandleTypeDef *htim, uint32_t Channel, float percent);
            Set_Motor_Duty(&htim1, TIM_CHANNEL_1, new_duty);
            char msg[30];
            int len = sprintf(msg, "\r\nSet to: %.1f%%\r\n>> ", new_duty);
            HAL_UART_Transmit(huart, (uint8_t*)msg, len, 10);
            rx_index = 0;
        } else {
            HAL_UART_Transmit(huart, &rx_data, 1, 10);
            if (rx_index < sizeof(rx_buffer) - 1) {
                rx_buffer[rx_index++] = rx_data;
            }
        }
        HAL_UART_Receive_IT(huart, &rx_data, 1);
    }
}
