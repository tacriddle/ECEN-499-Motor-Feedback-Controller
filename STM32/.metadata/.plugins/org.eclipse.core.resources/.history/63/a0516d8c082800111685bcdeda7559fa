/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_DMA_Init();
  MX_USART2_UART_Init();
  MX_TIM1_Init();
  MX_I2C1_Init();
  MX_TIM8_Init();
  MX_TIM3_Init();
  MX_USART3_UART_Init();
  /* USER CODE BEGIN 2 */

  HAL_TIM_Base_Start_IT(&htim8);
  Motor_Init();
  RPM_Sensor_Init();
  Telemetry_Init();
  LCD_Init();

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */


	  // Process new RPM data from sensor
	  if (new_rpm_data) {
		  RPM_Process_Data();
	  }


	  // timeout logic to detect when RPM = 0 (If no pulses seen for too long, set RPM to zero)
	  if (HAL_GetTick() - last_tick > (uint32_t)timeout_ms) {
		  current_rpm = 0;
		  median_buffer[0] = median_buffer[1] = median_buffer[2] = 0;
	  }


//	  if (esp32_transmit_flag == 1) {
//	      esp32_transmit_flag = 0;
//	      Telemetry_Transmit_ESP32();
//	  }

	  // transmit current RPM and PWM to ESP32 for graphing every 100ms
	  if (HAL_GetTick() - last_ESP32_transmit >= 100) {
		  Telemetry_Transmit_ESP32();
	  }


	  // transmit current RPM and PWM to LCD every 200ms
	  if (HAL_GetTick() - last_LCD_update >= 200) {
		  LCD_Update_Display();
	  }


  }

  /* USER CODE END 3 */
}

