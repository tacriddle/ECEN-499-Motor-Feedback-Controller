#ifndef INC_RPM_SENSOR_H_
#define INC_RPM_SENSOR_H_

#include "main.h"

// DMA_BUF_SIZE: Number of pulse timestamps stored in RAM before the buffer wraps.
// A larger buffer provides a "safety cushion," giving the CPU more time to
// process data before the DMA hardware overwrites it.
#define DMA_BUF_SIZE	36

// SLOTS_ON_DISK: The physical number of holes/slots in your optical encoder disk.
// This is the primary constant for converting pulse frequency to shaft rotation.
#define SLOTS_ON_DISK  	18

// MINIMUM_RPM: The speed floor. If the time between pulses exceeds the time
// equivalent to this RPM, the 'timeout logic' will force the RPM to 0.
// Prevents the system from displaying a "stale" RPM when the motor stops.
// The higher the MINIMUM_RPM, the shorter the timeout time
#define MINIMUM_RPM    	50

// CALC_WINDOW_SIZE: The number of pulses averaged for a single RPM calculation.
// Since we process data at the Half-Transfer and Transfer-Complete interrupts,
// we calculate RPM every (DMA_BUF_SIZE / 2) pulses.
#define CALC_WINDOW_SIZE (DMA_BUF_SIZE / 2)

// Global variables needed by other modules
extern float current_rpm;
extern volatile uint8_t new_rpm_data;
extern uint32_t last_tick;
extern float timeout_ms;

// Function Prototypes
void RPM_Sensor_Init(void);
void RPM_Process_Data(void);
void RPM_Update_From_DMA(void);

// Helper to swap two floats
void swap(float *p, float *q) {
    float t = *p;
    *p = *q;
    *q = t;
}

float get_median_of_3(float a, float b, float c) {
    float buf[3] = {a, b, c};
    if (buf[0] > buf[1]) swap(&buf[0], &buf[1]);
    if (buf[1] > buf[2]) swap(&buf[1], &buf[2]);
    if (buf[0] > buf[1]) swap(&buf[0], &buf[1]);
    return buf[1];
}

float get_median_of_5(float a, float b, float c, float d, float e) {
    float buf[5] = {a, b, c, d, e};
    for (int i = 0; i < 4; i++) {
        for (int j = 0; j < 4 - i; j++) {
            if (buf[j] > buf[j + 1]) swap(&buf[j], &buf[j + 1]);
        }
    }
    return buf[2]; // The middle element
}

float get_median_of_7(float a, float b, float c, float d, float e, float f, float g) {
    float buf[7] = {a, b, c, d, e, f, g};
    for (int i = 0; i < 6; i++) {
        for (int j = 0; j < 6 - i; j++) {
            if (buf[j] > buf[j + 1]) swap(&buf[j], &buf[j + 1]);
        }
    }
    return buf[3]; // The middle element
}

#endif /* INC_RPM_SENSOR_H_ */
