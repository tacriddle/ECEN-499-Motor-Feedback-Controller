#include <stdio.h>
#include "rpm_sensor.h"

extern TIM_HandleTypeDef htim2;
extern TIM_HandleTypeDef htim3;
extern DMA_HandleTypeDef hdma_tim2_ch1;

uint32_t capture_buffer[DMA_BUF_SIZE];

// Indices for the end of the first half and total buffer
// These define our "capture windows" for the DMA interrupts
uint8_t CALC_WINDOW_MAX_IDX = CALC_WINDOW_SIZE - 1;
uint8_t DMA_BUF_MAX_IDX = DMA_BUF_SIZE - 1;

// Conversion Constant Calculation:
// We measure ticks between pulses. To get RPM:
// RPM = (60,000,000 us/min) / (Time for 1 revolution in us)
// Time for 1 rev = (Avg time between pulses) * SLOTS_ON_DISK
float conversion_factor = (60000000.0f * CALC_WINDOW_SIZE) / SLOTS_ON_DISK;

uint32_t last_pulse_timestamp = 0; 	// Stores the final timestamp of the previous DMA batch
volatile uint32_t period_ticks = 0; // Raw timer ticks over the current window
volatile uint8_t new_rpm_data = 0;  // Semaphore flag to signal main loop processing
float current_rpm = 0; 				// Resultant filtered RPM

// Sliding window for spike rejection
//float median_buffer[7] = {0, 0, 0, 0, 0, 0, 0};
//float median_buffer[5] = {0, 0, 0, 0, 0};
float median_buffer[3] = {0, 0, 0};
uint8_t median_idx = 0;

// Smoothing factor (Lower = smoother but slower response. 5% weight to new data, 95% to history)
float rpm_alpha = 0.3f;

// Calculate max allowable time between pulses before assuming motor has stopped
float timeout_ms = 60000.0f / (MINIMUM_RPM * SLOTS_ON_DISK);
uint32_t last_tick = 0; // For timeout logic


void RPM_Sensor_Init(void) {
	// This tells the DMA: "Every time TIM3 captures a value, put it in capture_buffer."
//    HAL_TIM_IC_Start_DMA(&htim3, TIM_CHANNEL_3, capture_buffer, DMA_BUF_SIZE);
    HAL_TIM_IC_Start_DMA(&htim2, TIM_CHANNEL_1, capture_buffer, DMA_BUF_SIZE);
}


#define REVS_TO_AVERAGE 3  // How many physical revolutions to average together
#define HISTORY_BUFFER_SIZE (SLOTS_ON_DISK * REVS_TO_AVERAGE)
uint16_t dma_read_idx = 0;
// Rolling Window Variables
uint32_t slot_history[SLOTS_ON_DISK] = {0};
uint8_t slot_idx = 0;
uint8_t wheel_synced = 0;
// Executes inside the TIM8 10ms hardware interrupt
void RPM_Update_From_DMA(void) {
    // 1. Where is the DMA write pointer right now?
    uint16_t dma_write_idx = DMA_BUF_SIZE - hdma_tim2_ch1.Instance->NDTR;
    if (dma_write_idx >= DMA_BUF_SIZE) dma_write_idx = 0;

    uint8_t processed_new_data = 0;

    // 2. Unload the DMA Buffer instantly
    while (dma_read_idx != dma_write_idx) {

        uint32_t capture_val = capture_buffer[dma_read_idx];
        uint32_t period_ticks = capture_val - last_pulse_timestamp;
        last_pulse_timestamp = capture_val;

        // Advance read pointer
        dma_read_idx++;
        if (dma_read_idx >= DMA_BUF_SIZE) dma_read_idx = 0;

        // Bounce Protection (Ignore anything over 15,000 RPM)
        if (period_ticks < 222 || period_ticks == 0) continue;

		// Add to Rolling Multi-Rev Buffer
		slot_history[slot_idx] = period_ticks;
		slot_idx++;
		if (slot_idx >= HISTORY_BUFFER_SIZE) {
			slot_idx = 0;
			wheel_synced = 1;
		}

		processed_new_data = 1;
	} // End of the while loop

	// 3. Calculate Math ONCE per 10ms Interrupt
	if (wheel_synced && processed_new_data) {
		uint32_t total_ticks = 0;

		// Sum up all ticks in the massive flywheel buffer
		for (int i = 0; i < HISTORY_BUFFER_SIZE; i++) {
			total_ticks += slot_history[i];
		}

		// Calculate raw RPM. Because our buffer holds multiple revolutions,
		// we must multiply the numerator by the number of revolutions!
		float instant_rpm = (60000000.0f * REVS_TO_AVERAGE) / (float)total_ticks;

		// --- 4. The Outlier Assassin (Median of 3) ---
		// Shift old data out, put new data in
		median_buffer[0] = median_buffer[1];
		median_buffer[1] = median_buffer[2];
		median_buffer[2] = instant_rpm;

		// Get the middle value to instantly kill sudden mechanical jerks
		float med_rpm = get_median_of_3(median_buffer[0], median_buffer[1], median_buffer[2]);

		// --- 5. The Final Polish (Alpha Filter) ---
		// Since the Flywheel and Median filters did the heavy lifting,
		// we can relax this alpha to 15% to keep the loop highly responsive.
		current_rpm = (0.15f * med_rpm) + (0.85f * current_rpm);

		last_tick = HAL_GetTick();
	}
}
